---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORIES, type CategorySlug } from '../../lib/categories';

export async function getStaticPaths() {
  return Object.keys(CATEGORIES).map((category) => ({ params: { category } }));
}

const category = Astro.params.category as CategorySlug;
const cat = CATEGORIES[category];

const posts = (
  await getCollection('posts', ({ data }) => !data.draft && data.category === category)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={`${cat.label} — neuro-slop.ru`} description={cat.description}>
  <main class="mx-auto w-full max-w-[1440px] px-5 pt-16 md:px-10">
    <p class="mb-3 text-5xl">{cat.emoji}</p>
    <h1 class="text-[clamp(2.5rem,6vw,4.5rem)] font-bold tracking-[-0.03em]">{cat.label}</h1>
    <p class="text-muted-foreground mt-3 mb-12 max-w-2xl text-xl font-medium">{cat.description}</p>

    {
      posts.length > 0 ? (
        <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <div class="bg-card/60 border-border/60 rounded-2xl border px-8 py-16 text-center backdrop-blur-sm">
          <p class="text-muted-foreground">Здесь пока пусто — записи появятся позже.</p>
        </div>
      )
    }

    <p class="mt-14">
      <a href="/posts/" class="text-primary text-sm font-medium hover:underline">← Все записи</a>
    </p>
  </main>
</Layout>
