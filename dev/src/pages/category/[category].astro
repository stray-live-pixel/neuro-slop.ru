---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORIES, type CategorySlug } from '../../lib/categories';

export async function getStaticPaths() {
  return Object.keys(CATEGORIES).map((category) => ({ params: { category } }));
}

const category = Astro.params.category as CategorySlug;
const cat = CATEGORIES[category];

const posts = (
  await getCollection('posts', ({ data }) => !data.draft && data.category === category)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={`${cat.label} — neuro-slop.ru`} description={cat.description}>
  <main class="container">
    <p class="emoji">{cat.emoji}</p>
    <h1>{cat.label}</h1>
    <p class="lede">{cat.description}</p>

    {
      posts.length > 0 ? (
        <div class="grid">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="empty">Здесь пока пусто — записи появятся позже.</p>
      )
    }

    <p class="back"><a href="/posts/">← Все записи</a></p>
  </main>
</Layout>

<style>
  main {
    padding-top: 4rem;
  }

  .emoji {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
  }

  .lede {
    margin: 0.75rem 0 2.5rem;
    font-size: 1.25rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .empty {
    color: var(--text-secondary);
    padding: 3rem 0;
  }

  .back {
    margin-top: 3rem;
  }
</style>
