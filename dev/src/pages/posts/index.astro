---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORIES } from '../../lib/categories';

const posts = (
  await getCollection('posts', ({ data }) => import.meta.env.DEV || !data.draft)
).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Записи — neuro-slop.ru">
  <main class="mx-auto w-full max-w-[1440px] px-5 pt-16 md:px-10">
    <h1 class="text-[clamp(2.5rem,6vw,4.5rem)] font-bold tracking-[-0.03em]">Записи</h1>

    <div class="mt-7 mb-10 flex flex-wrap gap-2">
      {
        Object.entries(CATEGORIES).map(([slug, cat]) => (
          <a
            class="bg-card/60 border-border/60 text-foreground/90 hover:border-primary/50 hover:text-foreground rounded-full border px-4 py-1.5 text-sm font-medium backdrop-blur-sm transition-colors"
            href={`/category/${slug}/`}
          >
            {cat.emoji} {cat.label}
          </a>
        ))
      }
    </div>

    <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </main>
</Layout>
