---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { CATEGORIES } from '../lib/categories';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latest = posts.slice(0, 6);
---

<Layout>
  <main>
    <section class="hero">
      <p class="badge">Лаборатория ИИ-экспериментов</p>
      <h1><span class="gradient">neuro‑slop</span>.ru</h1>
      <p class="subtitle">
        Эксперименты с нейросетями: статьи, промпты,<br />наблюдения и сравнения моделей.
      </p>
      <a class="button" href="/posts/">Смотреть записи</a>
    </section>

    <section class="container">
      <h2>Разделы</h2>
      <div class="grid">
        {
          Object.entries(CATEGORIES).map(([slug, cat]) => (
            <a class="category-card" href={`/category/${slug}/`}>
              <span class="emoji">{cat.emoji}</span>
              <h3>{cat.label}</h3>
              <p>{cat.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="container">
      <div class="section-head">
        <h2>Свежее</h2>
        <a href="/posts/">Все записи →</a>
      </div>
      <div class="grid">
        {latest.map((post) => <PostCard post={post} />)}
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 7rem 1.5rem 6rem;
  }

  .badge {
    display: inline-block;
    margin-bottom: 1.25rem;
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    background: var(--card-bg);
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 500;
  }

  /* Градиент в духе Apple Intelligence */
  .gradient {
    background: linear-gradient(108deg, #0894ff 4%, #c959dd 51%, #ff2e54 78%, #ff9004 97%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .subtitle {
    margin-top: 1rem;
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .hero .button {
    margin-top: 2rem;
  }

  section.container {
    margin-bottom: 4rem;
  }

  section.container h2 {
    margin-bottom: 1.5rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.75rem;
    background: var(--card-bg);
    border-radius: var(--radius-card);
    color: var(--text);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .category-card:hover {
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
  }

  .category-card .emoji {
    font-size: 1.75rem;
  }

  .category-card h3 {
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }

  .category-card p {
    color: var(--text-secondary);
    font-size: 15px;
  }
</style>
