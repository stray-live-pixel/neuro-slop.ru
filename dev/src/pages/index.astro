---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { CATEGORIES } from '../lib/categories';
import { Icon } from '@/components/ui/icon';

const posts = (
  await getCollection('posts', ({ data }) => import.meta.env.DEV || !data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = posts.slice(0, 5);
---

<Layout>
  <main>
    <!-- Hero на весь экран -->
    <section class="relative flex min-h-[64svh] flex-col items-center justify-center px-5 py-16 text-center">
      <p
        class="bg-card/60 border-border/60 text-muted-foreground mb-6 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-medium backdrop-blur-sm"
      >
        <span class="relative flex size-2">
          <span class="bg-primary absolute inline-flex h-full w-full animate-ping rounded-full opacity-60"></span>
          <span class="bg-primary relative inline-flex size-2 rounded-full"></span>
        </span>
        Лаборатория ИИ-экспериментов
      </p>

      <h1 class="text-[clamp(3.25rem,9vw,8rem)] leading-[0.98] font-bold tracking-[-0.035em] text-balance">
        <span class="text-gradient text-gradient-animated">neuro‑slop.ru</span>
      </h1>

      <p class="text-muted-foreground mt-6 max-w-2xl text-[clamp(1.2rem,2.4vw,1.55rem)] leading-snug font-medium tracking-tight text-balance">
        Игры, сгенерированные нейросетями, и новости из мира ИИ.
      </p>

      <a
        href="/posts/"
        class="glass-button text-foreground mt-10 inline-flex h-14 items-center justify-center rounded-full px-12 text-lg font-bold"
      >
        Смотреть записи
      </a>
    </section>

    <!-- Свежие записи -->
    <section class="mx-auto w-full max-w-[1440px] px-5 py-10 md:px-10">
      <div class="mb-8 flex items-baseline justify-between gap-4">
        <h2 class="text-[clamp(1.9rem,3.5vw,2.75rem)] font-bold tracking-tight">Свежие записи</h2>
        <a href="/posts/" class="text-primary text-sm font-medium hover:underline">Все записи →</a>
      </div>
      <div class="grid grid-cols-1 gap-5 xl:grid-cols-2">
        {latest.map((post) => <PostCard post={post} />)}
      </div>
    </section>

    <!-- Разделы -->
    <section class="mx-auto w-full max-w-[1440px] px-5 py-10 md:px-10">
      <h2 class="mb-8 text-[clamp(1.9rem,3.5vw,2.75rem)] font-bold tracking-tight">Разделы</h2>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          Object.entries(CATEGORIES).map(([slug, cat]) => (
            <a
              class="glow-card bg-card/60 border-border/60 hover:shadow-xl group flex items-start gap-5 rounded-2xl border p-7 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1"
              href={`/category/${slug}/`}
            >
              <span
                class="flex size-14 shrink-0 items-center justify-center rounded-2xl text-white shadow-md"
                style={`background: ${cat.gradient}`}
              >
                <Icon name={cat.icon} class="size-7" />
              </span>
              <span class="flex flex-col gap-1.5">
                <h3 class="text-card-foreground text-xl font-semibold tracking-tight">{cat.label}</h3>
                <p class="text-muted-foreground text-[15px]">{cat.description}</p>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Манифест на всю ширину -->
    <section class="relative overflow-hidden px-5 py-20 text-center md:py-24">
      <p class="mx-auto max-w-[1100px] text-[clamp(1.75rem,4.5vw,3.5rem)] leading-[1.15] font-bold tracking-tight text-balance">
        Этот сайт — полигон. Здесь <span class="text-gradient">нейросети</span> пишут тексты,
        рисуют картинки и собирают целые игры.
      </p>
      <p class="text-muted-foreground mx-auto mt-6 max-w-xl text-lg">
        Всё, что получается — удачное и не очень, — выкладывается сюда как есть.
      </p>
    </section>
  </main>
</Layout>
