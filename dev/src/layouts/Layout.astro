---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'neuro-slop.ru',
  description = 'Скоро здесь что-то будет.',
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="brand">neuro‑slop.ru</a>
      </nav>
    </header>

    <slot />

    <footer>
      <p>© 2026 neuro-slop.ru</p>
    </footer>
  </body>
</html>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--nav-bg);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--separator);
  }

  nav {
    max-width: 980px;
    margin: 0 auto;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1rem;
  }

  .brand {
    color: var(--text);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .brand:hover {
    text-decoration: none;
  }

  footer {
    max-width: 980px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
    border-top: 1px solid var(--separator);
    color: var(--text-secondary);
    font-size: 12px;
    text-align: center;
  }
</style>
