---
import '../styles/global.css';
import Background from '../components/Background.astro';
import { ThemeToggle } from '@/components/ui/theme-toggle';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'neuro-slop.ru — эксперименты с нейросетями',
  description = 'Личная лаборатория экспериментов с нейросетями: игры, новости и промпты.',
  image = '/images/og.png',
} = Astro.props;

// Абсолютные URL для соцсетей и Телеграма (Astro.site задан в astro.config.mjs)
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="neuro-slop.ru" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{title}</title>
    <script is:inline>
      // Тема: localStorage → системная. Выполняется до отрисовки, чтобы не мигало.
      (() => {
        const stored = localStorage.getItem('theme');
        const dark =
          stored === 'dark' ||
          (!stored && matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', dark);

        window.__setTheme = (theme) => {
          document.documentElement.classList.toggle('dark', theme === 'dark');
          localStorage.setItem('theme', theme);
        };
      })();
    </script>

    <!-- Yandex.Metrika counter -->
    <script is:inline type="text/javascript">
      (function(m,e,t,r,i,k,a){
          m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
          m[i].l=1*new Date();
          for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
          k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
      })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=109813401', 'ym');

      ym(109813401, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/109813401" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Yandex.Metrika counter -->
  </head>
  <body class="bg-background text-foreground flex min-h-svh flex-col overscroll-none antialiased">
    <Background />

    <header
      class="bg-background/60 border-border/60 sticky top-0 z-50 border-b backdrop-blur-xl backdrop-saturate-150"
    >
      <nav
        class="mx-auto flex h-14 w-full max-w-[1920px] items-center justify-between px-5 md:px-10 2xl:px-16"
      >
        <a
          href="/"
          class="text-foreground text-[15px] font-semibold tracking-tight transition-opacity hover:opacity-70"
        >
          <span class="text-gradient text-gradient-animated">neuro‑slop.ru</span>
        </a>
        <div class="flex items-center gap-2">
          <a
            href="/posts/"
            class="text-foreground/80 hover:text-foreground hover:bg-accent rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
          >
            Записи
          </a>
          <ThemeToggle class="rounded-full" />
        </div>
      </nav>
    </header>

    <div class="flex-1">
      <slot />
    </div>

    <footer class="border-border/60 mt-16 border-t">
      <div
        class="text-muted-foreground mx-auto flex w-full max-w-[1920px] flex-col items-center justify-between gap-2 px-5 py-8 text-[13px] sm:flex-row md:px-10 2xl:px-16"
      >
        <p>© 2026 neuro-slop.ru</p>
        <p>Сделано вместе с нейросетями</p>
      </div>
    </footer>
  </body>
</html>
